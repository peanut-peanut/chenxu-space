# 生产环境变量 - 复制为 .env 并填写真实值
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_PASSWORD=change-db-password

JWT_SECRET=use-openssl-rand-base64-32
JWT_REFRESH_SECRET=use-another-openssl-rand-base64-32

OSS_ACCESS_KEY_ID=your-aliyun-access-key-id
OSS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
OSS_BUCKET=my-pan-disk
OSS_REGION=oss-cn-beijing
# OSS_ENDPOINT 用公网域名：presign 上传地址与图片显示 URL 都要让浏览器可访问
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

FEISHU_ALERT_WEBHOOK=
FEISHU_ALERT_SECRET=
FEISHU_ALERT_INTERVAL_MS=60000
