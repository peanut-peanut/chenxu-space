page {
  --color-bg: #f6f6f6;
  --color-white: #ffffff;
  --color-surface: #ffffff;

  --color-red: #d9982f;
  --color-red-light: rgba(217, 152, 47, 0.1);
  --color-gold: #d9982f;
  --color-gold-gradient: linear-gradient(135deg, #f2c879 0%, #d9982f 100%);

  --color-text-primary: #1a1a1a;
  --color-text-secondary: #555555;
  --color-text-tertiary: #aaaaaa;

  --color-border: #f0f0f0;
  --color-border-2: #e8e8e8;

  --color-emerald: #07c160;
  --color-rose: #ff2442;
  --color-amber: #ff9500;
  --color-blue: #1890ff;
  --color-purple: #722ed1;
  --color-cyan: #13c2c2;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 40rpx;
  --radius-full: 9999rpx;

  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  --shadow-card: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, input, button, scroll-view { box-sizing: border-box; }

/* 卡片 */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  animation: skeleton-shimmer 1.4s ease infinite;
  border-radius: var(--radius-md);
}
@keyframes skeleton-shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* 徽标 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}
.badge-daily      { color: #1890ff; background: rgba(24,144,255,0.1); }
.badge-sport      { color: #07c160; background: rgba(7,193,96,0.1); }
.badge-diet       { color: #ff9500; background: rgba(255,149,0,0.1); }
.badge-investment { color: #ff2442; background: rgba(255,36,66,0.1); }
.badge-literature { color: #13c2c2; background: rgba(19,194,194,0.1); }
.badge-idea       { color: #722ed1; background: rgba(114,46,209,0.1); }

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0 48rpx;
}
.btn::after { border: none; }
.btn-primary { background: var(--color-gold-gradient); color: #fff; }
.btn-secondary { background: #f5f5f5; color: var(--color-text-secondary); }
.btn-ghost { background: transparent; color: var(--color-text-secondary); }

/* 分割线 */
.divider { height: 1rpx; background: var(--color-border); }

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}
.no-more { color: var(--color-text-tertiary); }

/* 页面容器 */
.page-wrap { background: var(--color-bg); min-height: 100vh; }

/* 顶部标题区 */
.page-header {
  background: var(--color-white);
  padding: 24rpx 32rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.page-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: -0.5rpx;
}
.page-header-sub {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

/* tab 下划线风格 */
.tab-bar {
  display: flex;
  background: var(--color-white);
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  overflow-x: auto;
}
.tab-bar::-webkit-scrollbar { display: none; }

.tab-item {
  flex-shrink: 0;
  padding: 24rpx 20rpx 20rpx;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  position: relative;
  white-space: nowrap;
}
.tab-item--active {
  color: var(--color-text-primary);
  font-weight: 600;
}
.tab-item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-red);
  border-radius: 2rpx;
}
