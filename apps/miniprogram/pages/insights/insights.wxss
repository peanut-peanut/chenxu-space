/* 面板页 */
.page-wrap { background: var(--color-bg); }

.skeleton-wrap { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.skeleton-block { height: 360rpx; border-radius: var(--radius-xl); }

.content { padding: 20rpx 24rpx 120rpx; display: flex; flex-direction: column; gap: 20rpx; }

/* section 卡片 */
.section-card {
  background: var(--color-white);
  border-radius: var(--radius-xl);
  padding: 32rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.section-label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-sub {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  background: #f5f5f5;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
}

/* 数据行 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  align-items: center;
  background: #fafafa;
  border-radius: var(--radius-lg);
  padding: 24rpx 0;
  margin-bottom: 32rpx;
}

.stat-row { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.stat-label { font-size: 22rpx; color: var(--color-text-tertiary); }
.stat-value { font-size: 36rpx; font-weight: 700; color: var(--color-text-primary); }
.stat-unit { font-size: 20rpx; font-weight: 400; color: var(--color-text-tertiary); margin-left: 2rpx; }
.stat-divider { width: 1rpx; height: 40rpx; background: var(--color-border-2); }

/* 柱状图 */
.chart-wrap { margin-bottom: 24rpx; }
.chart-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.chart-title { font-size: 26rpx; font-weight: 600; color: var(--color-text-secondary); }
.chart-hint { font-size: 22rpx; color: var(--color-text-tertiary); }

.bar-chart {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  height: 160rpx;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  height: 100%;
}

.bar-track {
  flex: 1;
  width: 100%;
  background: #f0f0f0;
  border-radius: 8rpx 8rpx 0 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}

.bar {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.4s ease;
}
.bar--emerald { background: linear-gradient(180deg, #52d68a, #07c160); }
.bar--rose    { background: linear-gradient(180deg, #ff6b8a, #ff2442); }

.bar-label { font-size: 20rpx; color: var(--color-text-tertiary); }
.bar-count  { font-size: 20rpx; color: var(--color-text-secondary); font-weight: 600; }

/* 类型分布 */
.type-dist {
  border-top: 1rpx solid var(--color-border);
  padding-top: 24rpx;
  margin-top: 4rpx;
}

.dist-row { margin-bottom: 20rpx; }
.dist-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.dist-name  { font-size: 26rpx; color: var(--color-text-secondary); font-weight: 500; }
.dist-count { font-size: 22rpx; color: var(--color-text-tertiary); }

.dist-track {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: var(--radius-full);
  overflow: hidden;
}
.dist-bar { height: 100%; border-radius: var(--radius-full); }
.dist-bar--emerald { background: linear-gradient(90deg, #52d68a, #07c160); }

/* 最近记录 */
.recent-section { margin-bottom: 20rpx; }

.recent-type-label {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  margin-bottom: 16rpx;
}
.recent-type-label--emerald { color: var(--color-emerald); background: rgba(7,193,96,0.1); }
.recent-type-label--rose    { color: var(--color-rose);    background: rgba(255,36,66,0.08); }

.recent-empty { font-size: 26rpx; color: var(--color-text-tertiary); padding: 12rpx 0; }

.recent-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.recent-item:last-child { border-bottom: none; }

.recent-content {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.65;
}
.recent-time {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}
.recent-divider { height: 1rpx; background: var(--color-border); margin: 8rpx 0 24rpx; }
