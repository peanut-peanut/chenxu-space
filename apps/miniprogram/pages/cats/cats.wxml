<view class="page-wrap">
  <!-- 猫咪资料卡片 -->
  <view wx:if="{{cats.length > 0}}" class="cats-card-grid">
    <view
      wx:for="{{cats}}"
      wx:key="id"
      class="cat-card"
      bindtap="onCatFilter"
      data-value="{{item.id}}"
    >
      <image class="cat-card-avatar" src="{{item.avatarUrl}}" mode="aspectFill" lazy-load />
      <view class="cat-card-info">
        <view class="cat-card-name-row">
          <text class="cat-card-name">{{item.name}}</text>
          <text class="cat-card-gender cat-card-gender--{{item.gender.includes('公') ? 'male' : 'female'}}">{{item.genderSymbol}}</text>
        </view>
        <text class="cat-card-age">{{item.age}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选 tab -->
  <view class="filter-tab-bar">
    <view class="filter-tab {{cats.length > 0 && selectedCats.length === cats.length ? 'filter-tab--active' : ''}}" bindtap="onCatFilter" data-value="all">全部</view>
    <view
      wx:for="{{cats}}"
      wx:key="id"
      class="filter-tab {{selectedCats.length === 1 && selectedCats[0] === item.id ? 'filter-tab--active' : ''}}"
      bindtap="onCatFilter"
      data-value="{{item.id}}"
    >{{item.name}}</view>
    <view class="filter-tab {{mediaFilter === 'image' ? 'filter-tab--active' : ''}}" bindtap="onMediaFilter" data-value="image">照片</view>
    <view class="filter-tab {{mediaFilter === 'video' ? 'filter-tab--active' : ''}}" bindtap="onMediaFilter" data-value="video">视频</view>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading && media.length === 0}}" class="masonry-wrap">
    <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="skeleton" style="height: {{index % 2 === 0 ? 320 : 400}}rpx; border-radius: 24rpx;"></view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading && media.length === 0}}" class="empty-state">
    <text class="empty-icon">🐱</text>
    <text>还没有猫猫照片或视频</text>
  </view>

  <!-- 瀑布流 -->
  <view wx:else class="masonry-wrap">
    <view wx:for="{{media}}" wx:key="id" class="media-item" bindtap="onPreview" data-url="{{item.url}}" data-type="{{item.type}}">
      <view class="media-item-wrap">
        <image src="{{item.thumbUrl}}" mode="aspectFill" class="media-thumb" lazy-load />
        <view wx:if="{{item.type === 'video'}}" class="video-overlay">
          <text class="play-icon">▶</text>
        </view>
      </view>
      <view wx:if="{{item.note || item.dateLabel}}" class="media-info">
        <text wx:if="{{item.note}}" class="media-note-text">{{item.note}}</text>
        <text wx:if="{{item.dateLabel}}" class="media-date">{{item.dateLabel}}</text>
      </view>
    </view>
  </view>

  <view class="load-more">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{!hasMore && media.length > 0}}" class="no-more">已加载全部</text>
  </view>
</view>
