.page-wrap { background: var(--color-bg); }

/* 猫咪多选卡片行 */
.cats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 20rpx 24rpx 0;
}

.cat-pill {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-white);
  border-radius: var(--radius-xl);
  padding: 16rpx 24rpx;
  box-shadow: var(--shadow-card);
  flex: 1;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.cat-pill--active {
  border-color: var(--color-red);
  background: #fff8f9;
}

.cat-pill-emoji {
  font-size: 40rpx;
  flex-shrink: 0;
}

.cat-pill-info { flex: 1; min-width: 0; }

.cat-pill-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.cat-pill-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.cat-pill-gender {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}
.cat-pill-gender--female { color: #ff6b9d; background: rgba(255,107,157,0.1); }
.cat-pill-gender--male   { color: #4a90d9; background: rgba(74,144,217,0.1); }

.cat-pill-age {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 媒体类型 tab */
.media-tab-bar {
  display: flex;
  background: var(--color-white);
  padding: 0 24rpx;
  margin-top: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.media-tab {
  padding: 20rpx 24rpx 16rpx;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  position: relative;
}

.media-tab--active {
  color: var(--color-text-primary);
  font-weight: 600;
}

.media-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 4rpx;
  background: var(--color-red);
  border-radius: 2rpx;
}

/* 瀑布流 */
.masonry-wrap {
  padding: 16rpx 24rpx 120rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  align-items: start;
}

.media-item {
  background: var(--color-white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.media-item-wrap { position: relative; }

.media-thumb {
  width: 100%;
  display: block;
  min-height: 160rpx;
  background: #f5f5f5;
}

.video-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 72rpx;
  height: 72rpx;
  background: rgba(0,0,0,0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-icon { font-size: 28rpx; color: #fff; margin-left: 6rpx; }

.media-info { padding: 14rpx 16rpx 16rpx; }

.media-note-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.media-date {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
  display: block;
}
