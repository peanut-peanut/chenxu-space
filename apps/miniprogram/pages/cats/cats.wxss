.page-wrap {
  background: #f9f4ee;
  min-height: 100vh;
}

/* 猫咪资料卡片 */
.cats-card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  padding: 32rpx 32rpx 0;
}

.cat-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
 /* gap: 16rpx; */
  background: #fdf7e7;
  border-radius: 28rpx;
  padding: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(58, 39, 25, 0.08);
  transition: all 0.2s;
}

.cat-card:active {
  transform: scale(0.98);
}

.cat-card-avatar {
  width: 112rpx;
  height: 112rpx;
  display: block;
  flex-shrink: 0;
  /* border-radius: 28rpx;
  background: #ffffff; */
}

.cat-card-info {
  flex: 0 1 auto;
  min-width: 0;
  padding: 0;
}

.cat-card-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 2rpx;
}

.cat-card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #201c19;
  line-height: 1.25;
}

.cat-card-gender {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  flex-shrink: 0;
}
.cat-card-gender--female { color: #eb5aa4; background: rgba(235, 90, 164, 0.12); }
.cat-card-gender--male { color: #4f8edb; background: rgba(79, 142, 219, 0.12); }

.cat-card-age {
  font-size: 24rpx;
  color: #837b74;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 筛选 tab */
.filter-tab-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 24rpx 0;
  overflow-x: auto;
}

.filter-tab-bar::-webkit-scrollbar { display: none; }

.filter-tab {
  flex-shrink: 0;
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #938a82;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 56rpx;
  text-align: center;
  box-shadow: 0 4rpx 14rpx rgba(58, 39, 25, 0.04);
}

.filter-tab--active {
  background: #c4593b;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(196, 89, 59, 0.24);
}

/* 媒体网格 */
.masonry-wrap {
  padding: 20rpx 24rpx 120rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  align-items: start;
}

.media-item {
  background: transparent;
  border-radius: 20rpx;
  overflow: hidden;
}

.media-item-wrap { position: relative; }

.media-thumb {
  width: 100%;
  height: 214rpx;
  display: block;
  background: #eee5dc;
  border-radius: 20rpx;
}

.video-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 72rpx;
  height: 72rpx;
  background: rgba(0,0,0,0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-icon { font-size: 28rpx; color: #fff; margin-left: 6rpx; }

.media-info { padding: 10rpx 8rpx 12rpx; }

.media-note-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.media-date {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
  display: block;
}
