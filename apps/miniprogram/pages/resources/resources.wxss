/* 资源页 */
.page-wrap { background: var(--color-bg); }

.breadcrumb-wrap {
  background: var(--color-white);
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 9;
}

.breadcrumb { display: inline-flex; align-items: center; gap: 4rpx; flex-wrap: nowrap; }

.bc-item { display: inline-flex; align-items: center; }
.bc-text { font-size: 26rpx; color: var(--color-text-tertiary); }
.bc-text--link { color: var(--color-blue); }
.bc-text--current { color: var(--color-text-primary); font-weight: 600; }
.bc-sep { font-size: 24rpx; color: var(--color-text-tertiary); margin: 0 4rpx; }

.skeleton-list { padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.skeleton-row { height: 96rpx; border-radius: var(--radius-lg); }

.file-list { padding: 20rpx 24rpx 120rpx; display: flex; flex-direction: column; gap: 12rpx; }

.list-section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-tertiary);
  letter-spacing: 2rpx;
  padding: 12rpx 0 4rpx;
  text-transform: uppercase;
}

.file-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: var(--color-white);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.file-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: var(--radius-lg);
  background: #f8f8f8;
  flex-shrink: 0;
}

.file-icon--folder { background: rgba(255,149,0,0.08); }

.file-meta { flex: 1; min-width: 0; }

.file-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-sub {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

.file-arrow {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.file-type-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}
.file-type-tag--image  { color: var(--color-blue);    background: rgba(24,144,255,0.08); }
.file-type-tag--video  { color: var(--color-purple);  background: rgba(114,46,209,0.08); }
.file-type-tag--file   { color: var(--color-emerald); background: rgba(7,193,96,0.08);   }
