<view class="page-wrap">
  <!-- 面包屑 -->
  <scroll-view class="breadcrumb-wrap" scroll-x show-scrollbar="{{false}}">
    <view class="breadcrumb">
      <view class="bc-item" bindtap="onNavBreadcrumb" data-index="{{-1}}">
        <text class="bc-text bc-text--link">根目录</text>
      </view>
      <view wx:for="{{breadcrumb}}" wx:key="id" class="bc-item">
        <text class="bc-sep">›</text>
        <text
          class="bc-text {{index === breadcrumb.length - 1 ? 'bc-text--current' : 'bc-text--link'}}"
          bindtap="onNavBreadcrumb"
          data-index="{{index}}"
        >{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="skeleton skeleton-row"></view>
  </view>

  <view wx:elif="{{!loading && folders.length === 0 && files.length === 0}}" class="empty-state">
    <text class="empty-icon">📂</text>
    <text>暂无内容</text>
  </view>

  <view wx:else class="file-list">
    <view wx:if="{{folders.length > 0}}">
      <text wx:if="{{files.length > 0}}" class="list-section-title">文件夹</text>
      <view wx:for="{{folders}}" wx:key="id" class="file-row" bindtap="onOpenFolder" data-folder="{{item}}">
        <view class="file-icon file-icon--folder">📁</view>
        <view class="file-meta">
          <text class="file-name">{{item.name}}</text>
          <text class="file-sub">{{item.isPublic ? '公开' : '私有'}}</text>
        </view>
        <text class="file-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{files.length > 0}}">
      <text wx:if="{{folders.length > 0}}" class="list-section-title">文件</text>
      <view wx:for="{{files}}" wx:key="id" class="file-row" bindtap="onOpenFile" data-file="{{item}}">
        <view class="file-icon">{{item.icon}}</view>
        <view class="file-meta">
          <text class="file-name">{{item.name}}</text>
          <text class="file-sub">{{item.sizeLabel}}</text>
        </view>
        <text class="file-type-tag file-type-tag--{{item.type}}">{{item.type === 'image' ? '图片' : item.type === 'video' ? '视频' : '文件'}}</text>
      </view>
    </view>
  </view>
</view>
