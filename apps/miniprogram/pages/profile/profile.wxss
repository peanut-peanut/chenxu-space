.page-wrap {
  min-height: 100vh;
  background: #f9f4ee;
}

/* 身份区 */
.identity {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx 36rpx;
  background: #ffffff;
}

.identity:active { background: #fafafa; }

.avatar,
.avatar--empty {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f6ecd8;
}

.avatar--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f7e0a8 0%, #e8b866 100%);
}

.avatar-letter {
  font-size: 52rpx;
  font-weight: 600;
  color: #ffffff;
}

.identity-info {
  flex: 1;
  min-width: 0;
}

.identity-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-edit {
  flex-shrink: 0;
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2c879 0%, #d9982f 100%);
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(217, 152, 47, 0.28);
}

.identity-arrow {
  flex-shrink: 0;
  color: #cccccc;
  font-size: 44rpx;
  line-height: 1;
}

/* 数据统计 */
.stats {
  display: flex;
  align-items: center;
  padding: 8rpx 0 32rpx;
  background: #ffffff;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat:active { opacity: 0.6; }

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.2;
}

/* 功能列表 */
.list {
  margin-top: 20rpx;
  background: #ffffff;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 108rpx;
  padding: 0 32rpx;
}

.list-item:active { background: #fafafa; }

.list-item--center { justify-content: center; }

.li-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  background: #f6ecd8;
  position: relative;
}

/* 简约字符图标：用伪元素画符号，保持线性中性风 */
.li-icon::after {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
  color: #c99a3f;
}
.li-icon--cat::after   { content: '🐾'; }
.li-icon--chart::after { content: '▦'; }
.li-icon--bell::after  { content: '♪'; }
.li-icon--info::after  { content: 'ⓘ'; }

.li-title {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  line-height: 1.4;
}

.li-arrow {
  flex-shrink: 0;
  color: #d8c9b0;
  font-size: 40rpx;
  line-height: 1;
}

.li-logout {
  font-size: 30rpx;
  color: #c99a3f;
}

.list-divider {
  height: 1rpx;
  margin-left: 100rpx;
  background: #f2ead9;
}

.bottom-space { height: 60rpx; }
