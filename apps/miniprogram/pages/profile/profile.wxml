<view class="page-wrap">
  <!-- 身份区 -->
  <view class="identity" bindtap="onHeroTap">
    <image wx:if="{{user && user.avatar}}" class="avatar" src="{{user.avatar}}" mode="aspectFill" />
    <view wx:else class="avatar avatar--empty">
      <text class="avatar-letter">{{avatarLetter}}</text>
    </view>

    <view class="identity-info">
      <text class="identity-name">{{user ? user.nickname : '登录 / 注册'}}</text>
      <text class="identity-sub">{{user ? accountSub : '登录后同步点赞、收藏记录'}}</text>
    </view>

    <view wx:if="{{user}}" class="identity-edit">编辑</view>
    <text wx:else class="identity-arrow">›</text>
  </view>

  <!-- 数据统计 -->
  <view class="stats">
    <view class="stat" bindtap="onStat" data-key="likes">
      <text class="stat-num">{{stats.likes}}</text>
      <text class="stat-label">点赞</text>
    </view>
    <view class="stat" bindtap="onStat" data-key="favorites">
      <text class="stat-num">{{stats.favorites}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat" bindtap="onStat" data-key="footprint">
      <text class="stat-num">{{stats.footprint}}</text>
      <text class="stat-label">足迹</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="list">
    <view class="list-item" bindtap="onGoCats">
      <view class="li-icon li-icon--cat"></view>
      <text class="li-title">猫猫动态</text>
      <text class="li-arrow">›</text>
    </view>
    <view class="list-divider"></view>
    <view class="list-item" bindtap="onGoInsights">
      <view class="li-icon li-icon--chart"></view>
      <text class="li-title">数据面板</text>
      <text class="li-arrow">›</text>
    </view>
  </view>

  <view class="list">
    <view class="list-item" bindtap="onRequireLoginFeature" data-feature="消息通知">
      <view class="li-icon li-icon--bell"></view>
      <text class="li-title">消息通知</text>
      <text class="li-arrow">›</text>
    </view>
    <view class="list-divider"></view>
    <view class="list-item" bindtap="onAbout">
      <view class="li-icon li-icon--info"></view>
      <text class="li-title">关于</text>
      <text class="li-arrow">›</text>
    </view>
  </view>

  <view wx:if="{{user}}" class="list">
    <view class="list-item list-item--center" bindtap="onLogout">
      <text class="li-logout">退出登录</text>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
