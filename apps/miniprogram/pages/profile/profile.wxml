<view class="page-wrap">
  <!-- 已登录 -->
  <view wx:if="{{user}}">
    <!-- 背景 + 用户信息区 -->
    <view class="hero">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <image class="hero-avatar" src="{{user.avatar || ''}}" mode="aspectFill" />
        <view class="hero-info">
          <text class="hero-name">{{user.nickname}}</text>
          <text class="hero-sub">注册于 {{joinedAt}}</text>
        </view>
      </view>

      <!-- 数据行 -->
      <view class="hero-stats">
        <view class="hero-stat">
          <text class="hero-stat-num">{{user.role === 'admin' ? '管理员' : '用户'}}</text>
          <text class="hero-stat-label">身份</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-num">{{user.phone}}</text>
          <text class="hero-stat-label">手机号</text>
        </view>
      </view>
    </view>

    <!-- 快捷功能卡片行 -->
    <view class="shortcut-row">
      <view class="shortcut-item">
        <text class="shortcut-icon">📧</text>
        <text class="shortcut-label">{{user.email || '未设置邮箱'}}</text>
      </view>
    </view>

    <!-- 设置列表 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="onLogout">
        <text class="menu-icon">🚪</text>
        <text class="menu-label">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 未登录 -->
  <view wx:else>
    <view class="hero">
      <view class="hero-bg"></view>
      <view class="hero-content" bindtap="onGoLogin">
        <view class="hero-avatar-placeholder">
          <text class="hero-avatar-icon">👤</text>
        </view>
        <view class="hero-info">
          <text class="hero-name">登录 / 注册</text>
          <text class="hero-sub">登录后查看更多内容</text>
        </view>
      </view>

      <view class="hero-stats">
        <view class="hero-stat">
          <text class="hero-stat-num">—</text>
          <text class="hero-stat-label">日常</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-num">—</text>
          <text class="hero-stat-label">点赞</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-num">—</text>
          <text class="hero-stat-label">收藏</text>
        </view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="shortcut-row">
      <view class="shortcut-item" bindtap="onGoLogin">
        <text class="shortcut-icon">🔑</text>
        <text class="shortcut-label">手机号登录</text>
      </view>
    </view>

    <!-- 特性说明 -->
    <view class="menu-group">
      <view class="menu-item">
        <text class="menu-icon">❤️</text>
        <text class="menu-label">登录后可以点赞互动</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="divider"></view>
      <view class="menu-item">
        <text class="menu-icon">🐱</text>
        <text class="menu-label">查看猫猫动态</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="divider"></view>
      <view class="menu-item">
        <text class="menu-icon">📊</text>
        <text class="menu-label">查看完整数据面板</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
