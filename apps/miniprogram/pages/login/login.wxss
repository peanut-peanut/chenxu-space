.container {
  position: relative;
  min-height: 100vh;
  background: #f9f4ee;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  overflow: hidden;
}

.deco {
  position: fixed;
  font-size: 120rpx;
  opacity: 0.1;
  pointer-events: none;
  z-index: 0;
}
.deco-1 { top: 120rpx; right: -10rpx; transform: rotate(16deg); }
.deco-2 { bottom: 160rpx; left: -6rpx; transform: rotate(-12deg); }

.header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 110rpx;
  padding-bottom: 72rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(217, 152, 47, 0.28);
}

.logo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #3a2c1a;
  letter-spacing: -0.5rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #a08a6f;
  margin-top: 14rpx;
}

.form {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.field { display: flex; flex-direction: column; gap: 14rpx; }

.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #6b5a45;
  padding-left: 8rpx;
}

.input {
  height: 100rpx;
  background: #ffffff;
  border: 2rpx solid #efe4d3;
  border-radius: 28rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #3a2c1a;
}

.input-placeholder { color: #c4b39c; }

.error-msg {
  font-size: 26rpx;
  color: #c4593b;
  padding: 18rpx 24rpx;
  background: rgba(196, 89, 59, 0.08);
  border-radius: 16rpx;
}

.submit-btn {
  margin-top: 20rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f2c879 0%, #d9982f 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(217, 152, 47, 0.32);
}
.submit-btn::after { border: none; }
.submit-btn[disabled] { opacity: 0.7; color: #ffffff; }
