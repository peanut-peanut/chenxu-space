<view class="container">
  <view class="header">
    <view class="logo-wrap">
      <text class="logo-icon">✦</text>
    </view>
    <text class="title">chenxu.space</text>
    <text class="subtitle">登录以继续</text>
  </view>

  <view class="form">
    <view class="field">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="field">
      <text class="label">密码</text>
      <input
        class="input"
        type="safe-password"
        password
        placeholder="请输入密码"
        placeholder-class="input-placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view wx:if="{{error}}" class="error-msg">{{error}}</view>

    <button
      class="btn btn-primary submit-btn"
      bindtap="onSubmit"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登录'}}
    </button>
  </view>
</view>
