<view class="container">
  <view class="deco deco-1">🌿</view>
  <view class="deco deco-2">🐾</view>

  <view class="header">
    <view class="logo-wrap">
      <image class="logo-img" src="https://my-pan-disk.oss-cn-beijing.aliyuncs.com/%E5%85%B6%E4%BB%96%E8%B5%84%E6%BA%90/%E8%9B%8B%E9%BB%8466%E6%B2%99%E5%8F%91%E5%8D%A1%E9%80%9A%E7%89%88%E5%9C%86%E5%A4%B4%E5%83%8F.png" mode="aspectFill" />
    </view>
    <text class="title">你好呀，欢迎回来</text>
    <text class="subtitle">登录后同步你的点赞与收藏</text>
  </view>

  <view class="form">
    <view class="field">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="field">
      <text class="label">密码</text>
      <input
        class="input"
        type="safe-password"
        password
        placeholder="请输入密码"
        placeholder-class="input-placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view wx:if="{{error}}" class="error-msg">{{error}}</view>

    <button
      class="submit-btn"
      bindtap="onSubmit"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登录'}}
    </button>
  </view>
</view>
