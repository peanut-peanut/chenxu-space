/* 日常页 */
.page-wrap { background: var(--color-bg); }

/* tab 筛选 */
.type-scroll {
  background: var(--color-white);
  position: sticky;
  top: 0;
  z-index: 9;
  border-bottom: 1rpx solid var(--color-border);
}

.type-tabs {
  display: flex;
  padding: 0 8rpx;
  white-space: nowrap;
}

.type-tab {
  flex-shrink: 0;
  padding: 24rpx 24rpx 20rpx;
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  position: relative;
  white-space: nowrap;
}

.type-tab--active {
  color: var(--color-text-primary);
  font-weight: 600;
}

.type-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 4rpx;
  background: var(--color-red);
  border-radius: 2rpx;
}

/* 骨架屏 */
.skeleton-list {
  padding: 24rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.skeleton-card { height: 220rpx; border-radius: var(--radius-lg); }

/* 列表 */
.thought-list {
  padding: 20rpx 24rpx 120rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.thought-card {
  background: var(--color-white);
  border-radius: var(--radius-xl);
  padding: 28rpx 28rpx 20rpx;
  box-shadow: var(--shadow-card);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.card-meta { flex: 1; min-width: 0; }

.nickname {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
}

/* 内容 */
.content-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.75;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

/* 运动 meta */
.sport-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.sport-tag {
  font-size: 22rpx;
  color: var(--color-emerald);
  background: rgba(7,193,96,0.08);
  border-radius: var(--radius-full);
  padding: 6rpx 18rpx;
}

/* 图片网格 */
.image-grid {
  margin-top: 16rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.image-grid--one .grid-image {
  width: 100%;
  height: 380rpx;
  display: block;
  border-radius: var(--radius-lg);
}

.image-grid--two {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rpx;
}
.image-grid--two .grid-image { width: 100%; height: 260rpx; }

.image-grid--three {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 4rpx;
}
.image-grid--three .grid-image { width: 100%; height: 200rpx; }

/* 操作栏 */
.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

.action-icon { font-size: 30rpx; }
.action-btn--liked { color: var(--color-red); background: var(--color-red-light); }
.action-btn--disliked { color: var(--color-blue); background: rgba(24,144,255,0.08); }

/* 加载更多 */
.load-more-btn {
  color: var(--color-red);
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border: 1rpx solid rgba(217, 152, 47, 0.3);
  border-radius: var(--radius-full);
}
